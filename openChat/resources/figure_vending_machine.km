{"root":{"data":{"id":"dg6mawed4a80","created":1770252963315,"text":"figure_vending_machine","font-size":16},"children":[{"data":{"id":"dg6mb6jvk4g0","created":1770252985416,"text":"figure_vending_machine.c\ninit_base_widgets()","font-size":16,"layout":null},"children":[{"data":{"id":"dg6mbqurh540","created":1770253029610,"text":"初始化全局字体style","font-size":16,"layout":null},"children":[]}]},{"data":{"id":"dg6mbcdlk8g0","created":1770252998097,"text":"login_screen.c\nlogin_screen()","font-size":16,"layout":null},"children":[{"data":{"id":"dg6mc94wgvk0","created":1770253069405,"text":"login_screen.c\nlogin_screen_o\n创建登录screen","font-size":16,"layout":null},"children":[]},{"data":{"id":"dg6mcql175k0","created":1770253107386,"text":"login_screen.c\ntools_create_pinyin_ime(login_screen_o)\n添加键盘","font-size":16,"layout":null},"children":[]},{"data":{"id":"dg6meve9pc00","created":1770253274589,"text":"login_screen.c\nlogin_window()\n加载登录小窗","font-size":16,"layout":null},"children":[{"data":{"id":"dg6mfhcet740","created":1770253322366,"text":"输入框\n登录，注册按钮","font-size":16,"layout":null},"children":[{"data":{"id":"dg6mg6apucg0","created":1770253376683,"text":"login_screen.c\nlogin_btn_cb（lv_event_t * e）\n登录回调","font-size":16,"layout":null},"children":[{"data":{"id":"dg6miyub9c00","created":1770253595546,"text":"main_screen.c\nmain_screen()","layout":null,"font-size":16},"children":[{"data":{"id":"dg6mlwwheww0","created":1770253826417,"text":"//初始化全局listed_list\ninit_def_goods_to_list()\n使用默认商品信息变量，初始化listed_list链表","expandState":"expand","font-size":16,"layout":null},"children":[{"data":{"id":"dg6mpda2yyw0","created":1770254097160,"text":"goods_mangm.c\n定义listed_goods全局变量，存储已上架商品\ndata指针指向goods_info_t","font-size":16,"layout":null},"children":[{"data":{"id":"dg6mqndgjg80","created":1770254197496,"text":"typedef struct Goods_info_t{    //商品信息结构\n\tchar title[40];\n\tuint64_t price;\n\tchar goods_pic_path[100];\n\tuint32_t num;\n}goods_info_t;","font-size":16,"layout":null},"children":[]}]}]},{"data":{"id":"dg6mmb7d2wo0","created":1770253857549,"text":"//初始化已加购列表\ninit_shopping_cart_added_list();","layout":null,"font-size":16},"children":[{"data":{"id":"dg6msgjh1uo0","created":1770254339351,"text":"checkout.c\n定义shopping_cart_added_list 全局变量存储已加购商品列表\ndata指针指向wish_list_t","font-size":16,"layout":null},"children":[{"data":{"id":"dg6mtmwyovs0","created":1770254431591,"text":"//加购清单\ntypedef struct Wish_list_t{\n\tgoods_info_t * goods; //加购的商品\n\tuint32_t num;    //加购个数\n\n}wish_list_t;","font-size":16,"layout":null},"children":[]}]}]},{"data":{"id":"dg6mmpt550w0","created":1770253889341,"text":"//创建主窗口\nmain_screen_o=lv_obj_create(\nNULL);","layout":null,"font-size":16},"children":[]},{"data":{"id":"dg6mn8hh9uw0","created":1770253929995,"text":"//设置商品展示页面1大小\nlv_obj_set_size(main_screen_page1_o,800,480);","font-size":16,"layout":null},"children":[]},{"data":{"id":"dg6mnurq1280","created":1770253978504,"text":"//将商品添加到页面1上\ntools_dll_t * tmp = add_page_k_item_card(main_screen_page1_o, listed_goods);","layout":null,"font-size":16,"expandState":"expand"},"children":[{"data":{"id":"dg6mylg4h480","created":1770254820217,"text":"给页面添加商品页面小窗\n添加listed_goods里存储的商品到page_k_item_card链表\npage_k_item_card的data保存item_card_ros结构对象","font-size":16,"layout":null},"children":[{"data":{"id":"dg6n8kljoa80","created":1770255602010,"text":"typedef struct Item_card_ros{\n\tlv_obj_t * item_window;\n\tlv_obj_t * item_title_lb;\n\tlv_obj_t * item_sb;\n\tlv_obj_t * iten_price_lb;\n}item_card_ros;","font-size":16,"layout":null},"children":[]}]},{"data":{"id":"dg6n0wdk9w00","created":1770255000735,"text":"add_page_k_item_card（）函数返回值\n//保存所有创建的商品小窗对象的链表\ntools_dll_t * page_k_item_card = tools_init_dll_list();","font-size":16,"layout":null},"children":[]},{"data":{"id":"dg6n0l1a8o00","created":1770254976048,"text":"创建单个小窗的所有对象\nitem_card_ros * item_ret_o = create_main_screen_item_card（）","font-size":16,"layout":null},"children":[{"data":{"id":"dg6nb53sc800","created":1770255803377,"text":"// 设置商品标签\nlv_obj_t * item_title_lb = lv_label_create(item_window);","font-size":16,"layout":null},"children":[]},{"data":{"id":"dg6nc4ul1ns0","created":1770255881184,"text":" //设置滚轮\nlv_obj_t * item_spinbox = lv_spinbox_create(item_window);","font-size":16,"layout":null},"children":[]},{"data":{"id":"dg6nchxamw00","created":1770255909646,"text":"lv_obj_t * mp_btn = lv_btn_create(item_window); //两边的按钮","font-size":16,"layout":null},"children":[{"data":{"id":"dg6ncqy07og0","created":1770255929280,"text":"item_sb_increment_event_cb（）\n卡片窗口增加按钮回调","font-size":16,"layout":null},"children":[{"data":{"id":"dg6ne8p8y4g0","created":1770256046297,"text":"调整滚轮值\nlv_spinbox_increment((lv_obj_t *)e->user_data);","layout":null,"font-size":16},"children":[]},{"data":{"id":"dg6ney78g7c0","created":1770256101804,"text":"//查找触发回调的按钮所在商品卡片的商品title，根据此title查找已上架列表listed_goods，\nstrcpy(goods_title, get_goods_card_title(e->user_data));","layout":null,"font-size":16},"children":[]},{"data":{"id":"dg6ngu2tql40","created":1770256249559,"text":"根据此title查找已上架列表listed_goods，返回商品信息对象（goods_info_t）\nif((goods = find_listed_goods_list(listed_goods, goods_title)) != NULL){","layout":null,"font-size":16},"children":[{"data":{"id":"dg6nhrqwnm80","created":1770256322849,"text":"//将此商品加入加购列表\nadd_wish_list_goods(shopping_cart_added_list, goods);","font-size":16,"layout":null},"children":[{"data":{"id":"dg6nice4p7k0","created":1770256367789,"text":"//查找是否已经加购\n查找shopping_cart_added_list里有没有goods在之前查到的：（根据此title查找已上架列表listed_goods，返回商品信息对象（goods_info_t））","font-size":16,"layout":null},"children":[]},{"data":{"id":"dg6nik76ba80","created":1770256384782,"text":"//购物车没有，则加入\n\t    wish_list_t * new_shopping_cart_goods = (wish_list_t *)malloc(sizeof(wish_list_t));","font-size":16,"layout":null},"children":[{"data":{"id":"dg6nlvwf0yo0","created":1770256645346,"text":"保存查到的商品对象地址到shopping_cart_added_list全局链表里\n new_shopping_cart_goods->goods = goods;\n\t        new_shopping_cart_goods->num = 1;\n\t        //将新的加购链表对象加入已加购链表\n\t        tools_add_dll_list_node(shopping_cart_added_list, new_shopping_cart_goods);","font-size":16,"layout":null},"children":[]}]}]}]}]},{"data":{"id":"dg6nd6mbfk80","created":1770255963402,"text":"item_sb_decrement_event_cb（）\n卡片窗口减少按钮回调","font-size":16,"layout":null},"children":[{"data":{"id":"dg6nnktssqo0","created":1770256777971,"text":"减少按钮\nminus_wish_list_goods（）","font-size":16,"layout":null},"children":[{"data":{"id":"dg6npq2u8uw0","created":1770256946130,"text":"//查找是否已经加购\nfor(tools_dll_t * tmp_node = added_list->next; tmp_node != NULL; tmp_node = tmp_node->next)","font-size":16,"layout":null},"children":[]},{"data":{"id":"dg6no33mmx40","created":1770256817748,"text":"if(((wish_list_t*)(tmp_node->data))->num <= 0){ //已经减到0，删除此节点\ntools_delete_dll_list_node(shopping_cart_added_list, tmp_node);\n否则将已加购列表对象（shopping_cart_added_list）的data指向的wish_list_t类型的加购信息对象（((wish_list_t*)(tmp_node->data))）的加购计数器--\n((wish_list_t*)(tmp_node->data))->num --;","font-size":16,"layout":null},"children":[]}]}]}]}]},{"data":{"id":"dg6n9uyt7dk0","created":1770255702944,"text":"//添加商品小窗对象保存链表\ntools_add_dll_list_node(page_k_item_card, item_card_ros);","font-size":16,"layout":null},"children":[]}]},{"data":{"id":"dg6mo5pndqg0","created":1770254002323,"text":"//添加购物车相关功能\nshopping_cart(main_screen_o);","layout":null,"font-size":16},"children":[{"data":{"id":"dg6nxenwm740","created":1770257548196,"text":"//添加购物车按钮\nlv_obj_t * shopping_cart_btn = lv_btn_create(parent_o);","font-size":16,"layout":null},"children":[]},{"data":{"id":"dg6ny6bq6yg0","created":1770257608409,"text":" //显示购物车商品数量\nchar shopping_cart_btn_lb_text[50] = {\"\\0\"};\nsprintf(shopping_cart_btn_lb_text, \"购物车(%d)\", shopping_cart_num);\n//按钮标签\nlv_label_set_text(shopping_cart_btn_lb, shopping_cart_btn_lb_text); //设置标签文字","layout":null,"font-size":16},"children":[]}]}]}]},{"data":{"id":"dg6mhr255ig0","created":1770253500241,"text":"login_screen.c\nlogup_btn_cb(lv_event_t * e)\n注册回调","font-size":16,"layout":null},"children":[]}]}]}]}]},"template":"right","theme":"fresh-blue-compat","version":"1.4.43"}